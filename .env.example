# Herald MCP Server — environment configuration
#
# Copy this file to .env and fill in your values.
# Herald does NOT load .env automatically; use direnv, dotenv, or export vars manually.

# Base URL of the OpenRAG API (required).
# No trailing slash.
OPENRAG_BASE_URL=http://localhost:3000

# API key sent via x-api-key header to OpenRAG (optional if OpenRAG runs unauthenticated).
OPENRAG_API_KEY=

# TCP port for an optional future metrics/health endpoint (default: 8001).
LISTEN_PORT=8001

# Log level: debug | info | warn | error (default: info).
# Herald logs to stderr in JSON format; stdout is reserved for MCP stdio transport.
LOG_LEVEL=info
