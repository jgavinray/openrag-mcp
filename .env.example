# OpenRAG base URL
OPENRAG_URL=http://your-openrag-host:3000

# OpenRAG API key
OPENRAG_API_KEY=your_api_key_here

# Transport mode: "stdio" (default, for local MCP clients) or "http" (for network deployment)
HERALD_TRANSPORT=http

# Port for HTTP/SSE transport (default: 8080)
HERALD_PORT=8080

# Bind address for HTTP/SSE transport (default: 0.0.0.0)
# HERALD_ADDR=0.0.0.0
